---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout
  title="Blog | Sayantan Mishra"
  description="Thoughts on software engineering, backend systems, and the web."
>
  <div class="max-w-[900px] mx-auto px-6 md:px-12 lg:px-24 py-24">
    <h1 class="numbered-heading" style="counter-reset: section 0;">Blog</h1>
    <p class="mb-16 text-lg" style="color: var(--slate);">
      Thoughts on software engineering, backend systems, and the web.
    </p>

    {posts.length === 0 && (
      <p class="font-mono text-sm" style="color: var(--slate);">No posts yet. Check back soon.</p>
    )}

    <ul class="space-y-12 list-none p-0">
      {posts.map((post) => (
        <li class="fade-in-section is-visible">
          <a
            href={`/blog/${post.slug}`}
            class="group block no-underline"
          >
            <div
              class="p-8 rounded-lg border transition-all duration-300 group-hover:-translate-y-1"
              style="background: var(--light-navy); border-color: var(--lightest-navy); box-shadow: 0 4px 24px rgba(0,0,0,0.2);"
            >
              <time class="font-mono text-xs block mb-3" style="color: var(--green);">
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h2 class="text-xl font-bold mb-3 group-hover:text-teal-300 transition-colors" style="color: var(--lightest-slate);">
                {post.data.title}
              </h2>
              <p class="text-sm leading-relaxed" style="color: var(--slate);">
                {post.data.description}
              </p>
              {post.data.tags && (
                <ul class="flex flex-wrap gap-2 mt-4 list-none p-0">
                  {post.data.tags.map(tag => (
                    <li
                      class="font-mono text-xs px-3 py-1 rounded-full"
                      style="background: var(--lightest-navy); color: var(--green);"
                    >
                      {tag}
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</Layout>
